# Copy to .env and fill in real values. Never commit .env.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Host ports (dev only): change if 3000/5432 are already taken on your
# Docker host. Browse the API at http://<docker-host>:<API_HOST_PORT>.
API_HOST_PORT=3000
DB_HOST_PORT=5432

# POSTGRES_PASSWORD sets the db container's actual password; the password
# segment of DATABASE_URL must match it exactly, or the api container won't
# be able to connect. Defaults to gateway_dev_password if unset (fine for
# local dev, never use the default outside your own machine).
POSTGRES_PASSWORD=gateway_dev_password
DATABASE_URL=postgres://gateway:gateway_dev_password@db:5432/gateway

# Must be >= 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE_ME

# Set to false on staging/public deploys to close public self-registration
# (POST /api/v1/auth/register returns 403 instead of creating a user).
# REGISTRATION_ENABLED=false

# Optional: /docs (Swagger UI) is disabled unless both are set. Keep these
# private, they gate the only publicly reachable route that lists every
# endpoint and its request/response shape.
# DOCS_USERNAME=CHANGE_ME
# DOCS_PASSWORD=CHANGE_ME_16_CHARS_MIN

# Optional: the runtime error reporter is disabled unless both are set.
# Points at the control plane's error-report webhook when running the
# cross-repo local setup or staging.
# ERROR_WEBHOOK_URL=https://cp.example.dev/api/v1/webhooks/error-report
# ERROR_WEBHOOK_SECRET=CHANGE_ME

# Leave this commented out. The Docker image already has the real commit
# sha baked in (ARG COMMIT_SHA at build time; config.ts defaults to "dev"
# when unset). Setting it here would override the image's real value via
# env_file, on staging too, making every deploy falsely report "dev".
# COMMIT_SHA=dev
